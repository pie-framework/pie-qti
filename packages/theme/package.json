{
  "name": "@pie-qti/theme",
  "version": "0.1.13",
  "description": "Shared PIE QTI theme tokens and CSS variable contracts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp src/*.css dist/",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "qti",
    "qti2",
    "qti3",
    "assessment",
    "theme",
    "css-variables"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens.css": {
      "style": "./dist/tokens.css",
      "default": "./dist/tokens.css"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/theme"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/theme",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/*.css"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
