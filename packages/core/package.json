{
  "name": "@pie-qti/transform-core",
  "version": "0.1.12",
  "description": "Core transformation engine and plugin system for PIE Transform",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config/config-loader.js": {
      "types": "./dist/config/config-loader.d.ts",
      "import": "./dist/config/config-loader.js"
    },
    "./config/plugin-loader.js": {
      "types": "./dist/config/plugin-loader.d.ts",
      "import": "./dist/config/plugin-loader.js"
    },
    "./config/vendor-registry.js": {
      "types": "./dist/config/vendor-registry.d.ts",
      "import": "./dist/config/vendor-registry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "bun test tests",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pie",
    "qti",
    "assessment",
    "transformation",
    "plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "@pie-qti/element-schemas": "workspace:*",
    "@pie-qti/logger": "workspace:*",
    "@pie-qti/transform-types": "workspace:*",
    "ajv": "^8.17.1",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/core",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
