{
  "name": "@pie-qti/ims-cp-core",
  "version": "0.1.4",
  "description": "Core IMS Content Package manifest parsing utilities (browser + Node.js)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest-parser": {
      "types": "./dist/manifest-parser.d.ts",
      "import": "./dist/manifest-parser.js"
    },
    "./localized-resources": {
      "types": "./dist/localized-resources.d.ts",
      "import": "./dist/localized-resources.js"
    },
    "./passage-reusability": {
      "types": "./dist/passage-reusability.d.ts",
      "import": "./dist/passage-reusability.js"
    }
  },
  "dependencies": {
    "@pie-qti/logger": "workspace:*",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/ims-cp-core"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/ims-cp-core",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
