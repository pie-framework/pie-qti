{
  "name": "@pie-qti/item-player",
  "version": "0.1.1",
  "description": "Modern QTI player supporting QTI 2.x and 3.0 - Client-side with optional backend hooks",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.svelte.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "qti",
    "qti2",
    "qti3",
    "qti 2.x",
    "qti 3.0",
    "assessment",
    "player",
    "e-learning"
  ],
  "license": "MIT",
  "dependencies": {
    "@pie-qti/i18n": "workspace:*",
    "@pie-qti/ims-cp-core": "workspace:*",
    "@pie-qti/qti-common": "workspace:*",
    "@pie-qti/qti-processing": "workspace:*",
    "@tiptap/core": "^3.15.3",
    "@tiptap/extension-mathematics": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@xmldom/xmldom": "^0.8.11",
    "decimal.js": "^10.6.0",
    "katex": "^0.16.27",
    "mathlive": "^0.108.2",
    "node-html-parser": "^7.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.0.3",
    "svelte": "^5.54.0",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./web-components": {
      "types": "./dist/web-components/index.d.ts",
      "import": "./dist/web-components/index.js"
    },
    "./iframe": {
      "types": "./dist/iframe/index.d.ts",
      "import": "./dist/iframe/index.js"
    },
    "./components": {
      "svelte": "./src/components/index.ts"
    },
    "./components/utils": {
      "types": "./dist/components/utils/index.d.ts",
      "import": "./dist/components/utils/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/item-player"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/item-player",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "src"
  ]
}
