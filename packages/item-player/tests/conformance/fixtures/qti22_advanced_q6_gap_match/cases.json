{
  "id": "qti22_advanced_q6_gap_match",
  "cases": [
    {
      "name": "Q6-D1/D2: no response -> SCORE=0 (lowerBound=0 enforced)",
      "responses": { "RESPONSE": [] },
      "expect": {
        "score": 0,
        "outcomes": { "SCORE": 0 }
      }
    },
    {
      "name": "Q6-D1/D2: both correct (W G1, Su G2) -> SCORE=3",
      "responses": { "RESPONSE": ["W G1", "Su G2"] },
      "expect": {
        "score": 3,
        "outcomes": { "SCORE": 3 }
      }
    },
    {
      "name": "Q6-D1/D2: only W G1 correct -> SCORE=1",
      "responses": { "RESPONSE": ["W G1"] },
      "expect": {
        "score": 1,
        "outcomes": { "SCORE": 1 }
      }
    },
    {
      "name": "Q6-D1/D2: only Su G2 correct -> SCORE=2",
      "responses": { "RESPONSE": ["Su G2"] },
      "expect": {
        "score": 2,
        "outcomes": { "SCORE": 2 }
      }
    },
    {
      "name": "Q6-D1/D2: wrong pair (Sp G1) -> SCORE=0 (defaultValue=-1 but lowerBound=0)",
      "responses": { "RESPONSE": ["Sp G1"] },
      "expect": {
        "score": 0,
        "outcomes": { "SCORE": 0 }
      }
    },
    {
      "name": "Q6-D1/D2: correct + wrong pair -> clamps at 0 due to lowerBound",
      "responses": { "RESPONSE": ["W G1", "Sp G2"] },
      "expect": {
        "score": 0,
        "outcomes": { "SCORE": 0 }
      }
    }
  ]
}
