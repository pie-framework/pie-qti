        <setOutcomeValue identifier="SCORE">
          <sum>
            <variable identifier="SCORE" />
            <mapResponse identifier="response_3" />
          </sum>
        </setOutcomeValue>
        <setOutcomeValue identifier="SCORE_3">
          <mapResponse identifier="response_3" />
        </setOutcomeValue>
      </responseIf>
    </responseCondition>
  </responseProcessing>
