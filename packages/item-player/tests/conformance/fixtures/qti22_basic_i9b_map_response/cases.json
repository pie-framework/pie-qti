      "expect": {
        "score": 0,
        "outcomes": { "SCORE": 0 }
      }
    },
    {
      "name": "I9l1-D7: RESPONSE=[choice_a, choice_b] -> SCORE=3 (1+2=3)",
      "responses": { "RESPONSE": ["choice_a", "choice_b"] },
      "expect": {
        "score": 3,
        "outcomes": { "SCORE": 3 }
      }
    },
    {
      "name": "I9l1-D8: RESPONSE=[choice_b, choice_c] -> SCORE=6 (2+5=7, clamped to upperBound=6)",
