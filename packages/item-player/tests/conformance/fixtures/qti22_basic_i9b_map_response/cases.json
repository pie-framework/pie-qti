        "score": 4,
        "outcomes": { "SCORE": 4 }
      }
    },
    {
      "name": "I9l1-D10: RESPONSE=[choice_d, choice_e, choice_f] -> SCORE=0 (-1+-2+-5=-8, lowerBound clamp -> 0)",
