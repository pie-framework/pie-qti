      "expect": {
        "score": 1,
        "outcomes": { "SCORE": 1 }
      }
    },
    {
      "name": "I9l1-D3: RESPONSE=[choice_b] -> SCORE=2",
      "responses": { "RESPONSE": ["choice_b"] },
      "expect": {
        "score": 2,
        "outcomes": { "SCORE": 2 }
      }
    },
    {
      "name": "I9l1-D4: RESPONSE=[choice_c] -> SCORE=5",
      "responses": { "RESPONSE": ["choice_c"] },
      "expect": {
        "score": 5,
        "outcomes": { "SCORE": 5 }
      }
    },
    {
      "name": "I9l1-D5: RESPONSE=[choice_d] -> SCORE=0 (lowerBound clamp: -1 -> 0)",
