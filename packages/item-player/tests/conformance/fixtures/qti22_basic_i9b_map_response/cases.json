      "expect": {
        "score": 0,
        "outcomes": { "SCORE": 0 }
      }
    },
    {
      "name": "I9l1-D11: RESPONSE=[all six] -> SCORE=0 (1+2+5-1-2-5=0)",
      "responses": { "RESPONSE": ["choice_a", "choice_b", "choice_c", "choice_d", "choice_e", "choice_f"] },
      "expect": {
        "score": 0,
        "outcomes": { "SCORE": 0 }
      }
