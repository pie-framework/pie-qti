{
  "id": "responseProcessing_template_match_correct_two_responses",
  "cases": [
    {
      "name": "correct_RESPONSE_scores_one_even_when_OTHER_is_wrong",
      "responses": { "RESPONSE": "A", "OTHER": "A" },
      "expect": { "outcomes": { "SCORE": 1, "MAXSCORE": 2 } }
    },
    {
      "name": "incorrect_RESPONSE_scores_zero_even_when_OTHER_is_correct",
      "responses": { "RESPONSE": "B", "OTHER": "B" },
      "expect": { "outcomes": { "SCORE": 0, "MAXSCORE": 2 } }
    }
  ]
}

