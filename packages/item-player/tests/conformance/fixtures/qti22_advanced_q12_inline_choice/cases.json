        "score": 1,
        "outcomes": { "SCORE": 1 }
      }
    },
    {
      "name": "Q12-D4: RESPONSE=s (wrong) -> SCORE=0",
      "responses": { "RESPONSE": "s", "RESPONSE_1": null },
      "expect": {
        "score": 0,
        "outcomes": { "SCORE": 0 }
      }
    },
    {
      "name": "Q12-D5: both correct (w, Y) -> SCORE=2",
      "responses": { "RESPONSE": "w", "RESPONSE_1": "Y" },
      "expect": {
        "score": 2,
        "outcomes": { "SCORE": 2 }
      }
    },
    {
      "name": "Q12-D5: only RESPONSE_1 correct (Y) -> SCORE=1",
      "responses": { "RESPONSE": "s", "RESPONSE_1": "Y" },
      "expect": {
        "score": 1,
        "outcomes": { "SCORE": 1 }
      }
    },
    {
      "name": "Q12-D5: both wrong -> SCORE=0",
      "responses": { "RESPONSE": "a", "RESPONSE_1": "G" },
