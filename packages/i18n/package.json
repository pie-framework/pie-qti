{
  "name": "@pie-qti/i18n",
  "version": "0.1.14",
  "description": "Internationalization (i18n) package for PIE-QTI player ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./locales/*": "./dist/locales/*"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && if [ \"$PIE_QTI_DEV_FAST_BUILD\" = \"1\" ]; then tsc; else bun run check-translations && tsc; fi",
    "build:skip-check": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "clean": "rm -rf dist",
    "test": "bun test tests",
    "typecheck": "tsc --noEmit",
    "check-translations": "bun run scripts/check-translations.ts",
    "check-translations:locale": "bun run scripts/check-translations.ts --locale",
    "scan-hardcoded": "bun run scripts/scan-hardcoded-strings.ts"
  },
  "keywords": [
    "pie",
    "qti",
    "qti2",
    "qti3",
    "i18n",
    "internationalization",
    "localization"
  ],
  "license": "MIT",
  "devDependencies": {
    "svelte": "^5.43.3",
    "typescript": "^5.9.3",
    "@types/bun": "^1.3.11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/i18n"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/i18n",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
