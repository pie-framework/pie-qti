{
  "name": "@pie-qti/player-elements",
  "version": "0.1.15",
  "description": "QTI (2.x and 3.0) player web components (custom elements) for framework-agnostic embedding",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/public/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/public/register.d.ts",
      "import": "./dist/register.js"
    },
    "./elements": {
      "types": "./dist/public/elements.d.ts",
      "import": "./dist/elements.js"
    },
    "./register-players": {
      "types": "./dist/public/register-players.d.ts",
      "import": "./dist/register-players.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p ./tsconfig.build.json && tsc -p ./tsconfig.public.json",
    "test": "bun test && tsc -p ./tsconfig.types.test.json && tsc -p ./tsconfig.published-types.test.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "license": "MIT",
  "devDependencies": {
    "@pie-qti/assessment-player": "workspace:*",
    "@pie-qti/default-components": "workspace:*",
    "@pie-qti/item-player": "workspace:*",
    "@pie-qti/qti-common": "workspace:*",
    "@pie-qti/section-player": "workspace:*",
    "@biomejs/biome": "^2.4.8",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "linkedom": "^0.18.12",
    "svelte": "^5.54.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/player-elements"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/player-elements",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/register.js",
    "./dist/register-players.js",
    "./dist/tag-names-*.js"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ],
  "unpkg": "./dist/register.js",
  "jsdelivr": "./dist/register.js"
}
