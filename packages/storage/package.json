{
  "name": "@pie-qti/storage",
  "version": "0.1.7",
  "description": "Storage abstraction layer for PIE Transform framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./backends/filesystem": {
      "types": "./dist/backends/filesystem-backend.d.ts",
      "import": "./dist/backends/filesystem-backend.js",
      "default": "./dist/backends/filesystem-backend.js"
    },
    "./backends/s3": {
      "types": "./dist/backends/s3-backend.d.ts",
      "import": "./dist/backends/s3-backend.js",
      "default": "./dist/backends/s3-backend.js"
    },
    "./backends/database": {
      "types": "./dist/backends/database-backend.d.ts",
      "import": "./dist/backends/database-backend.js",
      "default": "./dist/backends/database-backend.js"
    },
    "./session-storage": {
      "types": "./dist/session-storage.d.ts",
      "import": "./dist/session-storage.js",
      "default": "./dist/session-storage.js"
    },
    "./zip-extractor": {
      "types": "./dist/zip-extractor.d.ts",
      "import": "./dist/zip-extractor.js",
      "default": "./dist/zip-extractor.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test tests"
  },
  "dependencies": {
    "@pie-qti/transform-types": "workspace:*",
    "adm-zip": "^0.5.16"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/bun": "^1.3.11",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/storage"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/storage",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
