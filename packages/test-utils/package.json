{
  "name": "@pie-qti/test-utils",
  "version": "0.1.16",
  "description": "Shared test utilities for PIE-QTI packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
