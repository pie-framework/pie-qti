    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/test-utils"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/test-utils",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
