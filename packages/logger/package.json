{
  "name": "@pie-qti/logger",
  "version": "0.1.8",
  "main": "./dist/index.js",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "description": "Universal logging utilities for PIE QTI (browser + Node.js)",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "qti",
    "logger",
    "logging",
    "universal",
    "isomorphic"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/logger"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/logger",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  }
}
