{
  "name": "@pie-qti/default-components",
  "version": "0.1.9",
  "description": "Default Svelte-based component implementations for QTI (2.x and 3.0) player",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "qti",
    "qti2",
    "qti3",
    "qti2.2",
    "assessment",
    "player",
    "components",
    "svelte",
    "web-components"
  ],
  "license": "MIT",
  "dependencies": {
    "@pie-qti/i18n": "workspace:*",
    "@pie-qti/item-player": "workspace:*",
    "@pie-qti/qti-common": "workspace:*",
    "@tiptap/core": "^3.15.3",
    "@tiptap/extension-mathematics": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "mathlive": "^0.108.2"
  },
  "peerDependencies": {
    "svelte": "^5.54.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.0.3",
    "svelte": "^5.54.0",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "vite": "^8.0.10"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./MathContent.svelte": {
      "svelte": "./src/shared/components/MathContent.svelte",
      "import": "./src/shared/components/MathContent.svelte",
      "default": "./src/shared/components/MathContent.svelte"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins.js",
      "default": "./dist/plugins.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./plugins/*/*.svelte": {
      "svelte": "./src/plugins/*/*.svelte",
      "import": "./src/plugins/*/*.svelte",
      "default": "./src/plugins/*/*.svelte"
    },
    "./plugins/*/index": {
      "types": "./dist/plugins/*/index.d.ts",
      "import": "./dist/plugins/*/index.js"
    },
    "./shared/components/*.svelte": {
      "svelte": "./src/shared/components/*.svelte",
      "import": "./src/shared/components/*.svelte",
      "default": "./src/shared/components/*.svelte"
    },
    "./shared/utils/*": {
      "types": "./dist/shared/utils/*.d.ts",
      "import": "./dist/shared/utils/*.js"
    },
    "./shared/actions/*": {
      "types": "./dist/shared/actions/*.d.ts",
      "import": "./dist/shared/actions/*.js"
    },
    "./shared/extensions/*": {
      "types": "./dist/shared/extensions/*.d.ts",
      "import": "./dist/shared/extensions/*.js"
    },
    "./src/shared/styles/qti-shared-vocabulary.css": {
      "style": "./src/shared/styles/qti-shared-vocabulary.css",
      "default": "./src/shared/styles/qti-shared-vocabulary.css"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/default-components"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/default-components",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/plugins.js",
    "./src/plugins/index.ts",
    "./src/plugins/**/*.svelte",
    "./src/catalog/*.svelte",
    "./src/shared/styles/*.css"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "unpkg": "./dist/plugins.js",
  "jsdelivr": "./dist/plugins.js"
}
