{
  "name": "@pie-qti/assessment-player",
  "version": "0.1.16",
  "description": "QTI Assessment Player supporting QTI 2.2 and 3.0 - Multi-item test player with navigation, sections, and rubric blocks",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "bun test --preload ./tests/setup.ts",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.svelte.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": [
    "qti",
    "qti2",
    "qti3",
    "qti 2.x",
    "qti 3.0",
    "assessment",
    "test",
    "player",
    "navigation",
    "e-learning"
  ],
  "license": "MIT",
  "dependencies": {
    "@pie-qti/assessment-toolkit": "workspace:*",
    "@pie-qti/default-components": "workspace:*",
    "@pie-qti/i18n": "workspace:*",
    "@pie-qti/ims-cp-core": "workspace:*",
    "@pie-qti/item-player": "workspace:*",
    "@pie-qti/qti-common": "workspace:*",
    "@pie-qti/qti-processing": "workspace:*",
    "@pie-qti/section-player": "workspace:*",
    "node-html-parser": "^7.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.0.3",
    "svelte": "^5.54.0",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./integration": {
      "types": "./dist/integration/index.d.ts",
      "import": "./dist/integration/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/assessment-player"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/assessment-player",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
