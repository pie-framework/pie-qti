{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": false,
		"rootDir": "..",
		"paths": {
			"@pie-qti/item-player/components": [
				"../item-player/src/components/index.ts"
			]
		},
		"types": [
			"svelte"
		]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.svelte",
		"src/**/*.d.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"**/*.test.ts"
	]
}
