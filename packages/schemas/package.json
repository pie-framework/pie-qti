{
  "name": "@pie-qti/element-schemas",
  "version": "0.1.10",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "description": "JSON schemas for PIE element validation",
  "keywords": [
    "pie",
    "schemas",
    "validation",
    "json-schema"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc && bun run copy-schemas",
    "copy-schemas": "mkdir -p dist/schemas && cp src/schemas/*.json dist/schemas/",
    "clean": "rm -rf dist",
    "sync": "bun run scripts/sync-schemas.ts",
    "check-updates": "bun run scripts/check-schema-versions.ts",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/schemas"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/schemas",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
