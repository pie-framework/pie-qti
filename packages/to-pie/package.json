{
  "name": "@pie-qti/to-pie",
  "version": "0.1.15",
  "description": "QTI to PIE transformation plugin",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node-package-transformer.d.ts",
      "import": "./dist/node-package-transformer.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pie",
    "qti",
    "qti",
    "qti2",
    "qti3",
    "qti2.2",
    "assessment",
    "transformation"
  ],
  "license": "MIT",
  "dependencies": {
    "@pie-qti/ims-cp-core": "workspace:*",
    "@pie-qti/ims-cp-node": "workspace:*",
    "@pie-qti/transform-core": "workspace:*",
    "@pie-qti/transform-types": "workspace:*",
    "image-size": "^2.0.2",
    "node-html-parser": "^6.1.13",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@pie-qti/test-utils": "workspace:*",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/to-pie"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/to-pie",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
