{
  "name": "@pie-qti/typeset-katex",
  "version": "0.1.5",
  "description": "KaTeX-based math typesetting adapter for PIE QTI players (supports QTI 2.2 and 3.0) (host-provided `typeset` function).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "import": "./dist/css.js"
    }
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "katex": "^0.16.27"
  },
  "devDependencies": {
    "linkedom": "^0.18.12",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/typeset-katex"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/typeset-katex",
  "bugs": {
    "url": "https://github.com/pie-framework/pie-qti/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ]
}
