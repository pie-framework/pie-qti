{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"strict": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*.ts", "src/**/*.svelte"],
	"exclude": ["node_modules", "dist"]
}
