  "license": "MIT",
  "dependencies": {
    "@pie-qti/transform-core": "workspace:*",
    "@pie-qti/transform-types": "workspace:*",
    "node-html-parser": "^6.1.13",
    "uuid": "^10.0.0",
    "xml-formatter": "^3.6.4"
  },
  "devDependencies": {
    "@pie-qti/to-pie": "workspace:*",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.3"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pie-framework/pie-qti.git",
    "directory": "packages/pie-to-qti2"
  },
  "homepage": "https://github.com/pie-framework/pie-qti/tree/master/packages/pie-to-qti2",
