<?xml version="1.0" encoding="UTF-8"?>
<assessmentItem xmlns="http://www.imsglobal.org/xsd/imsqti_v2p2"
                xmlns:examplecorp="http://www.examplecorp.com/qti/extensions"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                identifier="example-choice-001"
                title="ExampleCorp Sample Multiple Choice"
                adaptive="false"
                timeDependent="false">

  <!-- ExampleCorp Metadata (used for vendor detection) -->
  <examplecorp:metadata>
    <examplecorp:contentId>EC-12345</examplecorp:contentId>
    <examplecorp:difficulty>medium</examplecorp:difficulty>
    <examplecorp:tags>
      <examplecorp:tag>mathematics</examplecorp:tag>
      <examplecorp:tag>algebra</examplecorp:tag>
    </examplecorp:tags>
  </examplecorp:metadata>

  <!-- Tool metadata (another detection signal) -->
  <qti-metadata-field>
    <qti-metadata-value name="tool" value="ExampleCorp QTI Creator v3.5"/>
    <qti-metadata-value name="organization" value="ExampleCorp Education"/>
  </qti-metadata-field>

  <responseDeclaration identifier="RESPONSE" cardinality="single" baseType="identifier">
    <correctResponse>
      <value>choice_B</value>
    </correctResponse>
  </responseDeclaration>

  <outcomeDeclaration identifier="SCORE" cardinality="single" baseType="float">
    <defaultValue>
      <value>0</value>
    </defaultValue>
  </outcomeDeclaration>

  <itemBody>
    <div class="prompt">
      <p>What is the solution to the equation: 2x + 5 = 13?</p>
    </div>

    <choiceInteraction responseIdentifier="RESPONSE" shuffle="false" maxChoices="1">
      <prompt>Select the correct answer:</prompt>
      <simpleChoice identifier="choice_A">x = 3</simpleChoice>
      <simpleChoice identifier="choice_B">x = 4</simpleChoice>
      <simpleChoice identifier="choice_C">x = 5</simpleChoice>
      <simpleChoice identifier="choice_D">x = 6</simpleChoice>
    </choiceInteraction>
  </itemBody>

  <responseProcessing template="http://www.imsglobal.org/question/qti_v2p2/rptemplates/match_correct"/>

  <!-- ExampleCorp custom scoring (vendor-specific extension) -->
  <examplecorp:customScoring>
    <examplecorp:partialCredit enabled="true">
      <examplecorp:choice identifier="choice_A" credit="0.25"/>
      <examplecorp:choice identifier="choice_C" credit="0.25"/>
    </examplecorp:partialCredit>
  </examplecorp:customScoring>

</assessmentItem>
