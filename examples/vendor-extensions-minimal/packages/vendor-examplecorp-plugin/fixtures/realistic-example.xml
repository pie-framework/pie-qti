<?xml version="1.0" encoding="UTF-8"?>
<assessmentItem xmlns="http://www.imsglobal.org/xsd/imsqti_v2p2"
                xmlns:examplecorp="http://www.examplecorp.com/qti/extensions"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                identifier="photosynthesis-001"
                title="Understanding Photosynthesis"
                adaptive="false"
                timeDependent="false">

  <!-- ExampleCorp Metadata -->
  <examplecorp:metadata>
    <examplecorp:contentId>BIO-301-PS-001</examplecorp:contentId>
    <examplecorp:subject>Biology</examplecorp:subject>
    <examplecorp:grade>9</examplecorp:grade>
    <examplecorp:difficulty>medium</examplecorp:difficulty>
    <examplecorp:standards>
      <examplecorp:standard>NGSS-LS1-5</examplecorp:standard>
      <examplecorp:standard>CCSS-ELA-RST.9-10.4</examplecorp:standard>
    </examplecorp:standards>
    <examplecorp:author>Jane Smith</examplecorp:author>
    <examplecorp:createdAt>2025-12-15T10:30:00Z</examplecorp:createdAt>
  </examplecorp:metadata>

  <!-- Tool metadata -->
  <qti-metadata-field>
    <qti-metadata-value name="tool" value="ExampleCorp QTI Creator v3.5"/>
    <qti-metadata-value name="organization" value="ExampleCorp Education"/>
  </qti-metadata-field>

  <responseDeclaration identifier="RESPONSE" cardinality="single" baseType="identifier">
    <correctResponse>
      <value>choice_C</value>
    </correctResponse>
  </responseDeclaration>

  <outcomeDeclaration identifier="SCORE" cardinality="single" baseType="float">
    <defaultValue>
      <value>0</value>
    </defaultValue>
  </outcomeDeclaration>

  <itemBody>
    <div class="prompt">
      <p><strong>Question:</strong> Plants use photosynthesis to convert light energy into chemical energy.
      Which of the following best describes the primary product of photosynthesis that plants use for energy?</p>
    </div>

    <choiceInteraction responseIdentifier="RESPONSE" shuffle="false" maxChoices="1">
      <prompt>Select the best answer:</prompt>
      <simpleChoice identifier="choice_A">Oxygen (O₂)</simpleChoice>
      <simpleChoice identifier="choice_B">Carbon dioxide (CO₂)</simpleChoice>
      <simpleChoice identifier="choice_C">Glucose (C₆H₁₂O₆)</simpleChoice>
      <simpleChoice identifier="choice_D">Water (H₂O)</simpleChoice>
    </choiceInteraction>
  </itemBody>

  <responseProcessing template="http://www.imsglobal.org/question/qti_v2p2/rptemplates/match_correct"/>

  <!-- ExampleCorp custom scoring with partial credit -->
  <examplecorp:customScoring>
    <examplecorp:partialCredit enabled="true">
      <examplecorp:choice identifier="choice_A" credit="0.25">
        <examplecorp:rationale>Oxygen is a byproduct, not the primary energy product</examplecorp:rationale>
      </examplecorp:choice>
      <examplecorp:choice identifier="choice_B" credit="0.0">
        <examplecorp:rationale>CO₂ is a reactant, not a product</examplecorp:rationale>
      </examplecorp:choice>
      <examplecorp:choice identifier="choice_C" credit="1.0">
        <examplecorp:rationale>Correct! Glucose is the primary energy-storing molecule</examplecorp:rationale>
      </examplecorp:choice>
      <examplecorp:choice identifier="choice_D" credit="0.1">
        <examplecorp:rationale>Water is a reactant in the process</examplecorp:rationale>
      </examplecorp:choice>
    </examplecorp:partialCredit>
  </examplecorp:customScoring>

  <!-- ExampleCorp custom feedback -->
  <examplecorp:feedback>
    <examplecorp:hint level="1">Think about what plants produce that they can break down later for energy.</examplecorp:hint>
    <examplecorp:hint level="2">The chemical formula C₆H₁₂O₆ represents a sugar molecule.</examplecorp:hint>
    <examplecorp:explanation>
      During photosynthesis, plants convert light energy, carbon dioxide, and water into glucose (C₆H₁₂O₆)
      and oxygen. The glucose molecule stores chemical energy that the plant can later break down through
      cellular respiration to fuel its metabolic processes.
    </examplecorp:explanation>
  </examplecorp:feedback>

</assessmentItem>
