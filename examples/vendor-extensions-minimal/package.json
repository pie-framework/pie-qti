{
  "name": "@pie-qti-examples/vendor-extensions-minimal",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal example of PIE-QTI vendor extensions with custom plugin, web app, and CLI",
  "type": "module",
  "workspaces": [
    "packages/*",
    "tools/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:app": "turbo dev --filter=@pie-qti-examples/transform-web",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "turbo": "^2.7.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT"
}
