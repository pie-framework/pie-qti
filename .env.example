# ============================================
# PIE QTI Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ============================================
# NPM Publish Auth
# ============================================
# Required for local publishing via `bun run release:with-version` or `bun run release`.
# Get an npm token from: https://www.npmjs.com/settings/<username>/tokens
#
# Use an "Automation" token for scripted publishing (no OTP required).
# Use a "Publish" (granular) token for single-package or org-scoped publishing.
#
# In CI, set NPM_TOKEN as a GitHub Actions secret instead.

NPM_TOKEN=npm_...
