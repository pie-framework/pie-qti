	"commands": [
		{
			"id": "item-clean-room",
			"description": "Clean-room item fixture and extractor coverage",
			"cwd": ".",
			"args": [
				"test",
				"packages/item-player/tests/conformance/run-fixtures.test.ts",
				"packages/item-player/src/extraction/extractors/conformance.test.ts",
				"packages/item-player/src/extraction/extractors/conformance-qti3-basic.test.ts",
				"packages/item-player/src/extraction/extractors/conformance-qti3-advanced.test.ts"
			]
		},
		{
			"id": "assessment-clean-room",
			"description": "Clean-room assessment-player DELIVERY coverage",
			"cwd": ".",
			"args": [
				"test",
				"--preload",
				"./packages/assessment-player/tests/setup.ts",
				"packages/assessment-player/tests/conformance-qti22-basic.test.ts",
				"packages/assessment-player/tests/conformance-qti22-advanced.test.ts",
				"packages/assessment-player/tests/conformance-qti30-advanced.test.ts"
			]
		},
		{
			"id": "package-clean-room",
			"description": "Clean-room IMS CP and QTI 3 shared content parsing coverage",
			"cwd": ".",
			"args": ["test", "packages/ims-cp-core/tests/qti3-shared-content.test.ts"]
		},
		{
			"id": "item-runtime-clean-room",
			"description": "Clean-room item runtime session, PNP, and catalog behavior coverage",
			"cwd": ".",
			"args": [
				"test",
				"packages/item-player/tests/core/item-session-lifecycle.test.ts",
				"packages/item-player/tests/core/pnp.test.ts",
				"packages/item-player/tests/core/delivery-context.test.ts",
				"packages/item-player/tests/core/stimulusRender.test.ts",
				"packages/item-player/tests/core/stylesheetRender.test.ts",
				"packages/item-player/tests/core/glossaryTriggers.test.ts"
			]
		},
		{
			"id": "mathml-clean-room",
			"description": "MathML rendering coverage",
			"cwd": ".",
			"args": ["test", "packages/typeset-katex/tests/mathml.test.ts"]
		},
		{
			"id": "browser-visible",
			"description": "Targeted Playwright coverage for browser-visible certification behaviors",
			"cwd": "apps/demo",
			"args": ["run", "test:e2e", "--", "tests/playwright/public-certification.pw.ts"]
		},
		{
			"id": "browser-a11y-stage5",
			"description": "Targeted browser accessibility evidence for QTI 3 PNP/catalog/stimulus behavior",
			"cwd": "apps/demo",
			"args": ["run", "test:e2e", "--", "tests/playwright/qti3-stage5-a11y.pw.ts"]
		},
		{
			"id": "browser-a11y-assessment",
			"description": "Targeted browser accessibility evidence for assessment shell and timer behavior",
			"cwd": "apps/demo",
			"args": ["run", "test:e2e", "--", "tests/playwright/assessment-a11y-behavior.pw.ts"]
		}
